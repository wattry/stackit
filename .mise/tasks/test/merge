#!/usr/bin/env bash
#MISE description="Create a stack in jonnii/stackit-test and run merge against it"
#MISE depends=["build"]
set -euo pipefail

# Prevent any unexpected editors or pagers
export GIT_EDITOR=true
export EDITOR=true
export GIT_PAGER=cat
export PAGER=cat

STACKIT="$PROJECT_ROOT/bin/stackit"
REPO_OWNER="jonnii"
REPO_NAME="stackit-test"
WORK_DIR="$PROJECT_ROOT/tmp/test-merge"
REPO_DIR="$WORK_DIR/repo"

# Reuse existing repo if it exists (e.g. after a cancelled merge)
if [ -d "$REPO_DIR/.git" ]; then
  cd "$REPO_DIR"
  echo "==> Reusing existing repo in $REPO_DIR"
  "$STACKIT" log --no-interactive || true
  echo "==> Running: stackit merge $@"
  "$STACKIT" merge "$@"
  echo "==> Syncing to clean up merged branches"
  "$STACKIT" sync --no-interactive
  exit 0
fi

echo "==> Setting up fresh stack in $WORK_DIR"

# Clean up any previous state
rm -rf "$WORK_DIR"
mkdir -p "$WORK_DIR"

# Phase 1: Clean remote state
echo "==> Cleaning remote state"
for pr in $(gh api "repos/$REPO_OWNER/$REPO_NAME/pulls" --jq '.[].number' 2>/dev/null || true); do
  gh pr close "$pr" --repo "$REPO_OWNER/$REPO_NAME" --delete-branch 2>/dev/null || true
done
for branch in $(gh api "repos/$REPO_OWNER/$REPO_NAME/git/refs/heads" --jq '.[].ref | select(. != "refs/heads/main") | ltrimstr("refs/heads/")' 2>/dev/null || true); do
  gh api --method DELETE "repos/$REPO_OWNER/$REPO_NAME/git/refs/heads/$branch" 2>/dev/null || true
done
for ref in $(gh api "repos/$REPO_OWNER/$REPO_NAME/git/refs/stackit" --jq '.[].ref | ltrimstr("refs/")' 2>/dev/null || true); do
  gh api --method DELETE "repos/$REPO_OWNER/$REPO_NAME/git/refs/$ref" 2>/dev/null || true
done

# Phase 2: Clone and init
echo "==> Cloning and initializing"
git clone "git@github.com:$REPO_OWNER/$REPO_NAME.git" "$REPO_DIR"
cd "$REPO_DIR"
"$STACKIT" init --trunk main --no-interactive

# Phase 3: Create 3-branch stack
echo "==> Creating stack"
mkdir -p src
cat > src/feature.go << 'EOF'
package src

func Feature() string {
    return "hello from feature"
}
EOF
git add -A
"$STACKIT" create -m "feat: add feature module" --no-interactive

cat > src/feature_test.go << 'EOF'
package src

import "testing"

func TestFeature(t *testing.T) {
    if got := Feature(); got != "hello from feature" {
        t.Errorf("got %q, want %q", got, "hello from feature")
    }
}
EOF
git add -A
"$STACKIT" create -m "test: add feature tests" --no-interactive

cat > README.md << 'EOF'
# stackit-test
Test repository for stackit merge testing.
EOF
git add -A
"$STACKIT" create -m "docs: add documentation" --no-interactive

"$STACKIT" log --no-interactive

# Phase 4: Submit PRs
echo "==> Submitting stack"
"$STACKIT" submit --no-edit --no-interactive
sleep 2

# Phase 5: Run merge
echo "==> Running: stackit merge $@"
"$STACKIT" merge "$@"

# Phase 6: Sync to clean up merged branches (auto-confirms deletions)
echo "==> Syncing to clean up merged branches"
"$STACKIT" sync --no-interactive
